{
  "name": "language-coach-frontend",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ci": "vitest run --pool=forks --no-file-parallelism --testTimeout=5000 --teardownTimeout=5000",
    "e2e": "playwright test",
    "e2e:fullstack": "playwright test -c playwright.fullstack.config.ts"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9"
  }
}
