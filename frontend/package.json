{
  "name": "language-coach-frontend",
  "private": true,
  "version": "1.4.2",
  "type": "module",
  "engines": {
    "node": "22.18.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/utils src/services --config vitest.config.ts",
    "test:component": "vitest run src/views --config vitest.config.ts",
    "test:ci": "npm run test:unit && npm run test:component",
    "e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:fullstack": "playwright test -c playwright.fullstack.config.ts",
    "test:e2e:fullstack:smoke": "playwright test -c playwright.fullstack.smoke.config.ts",
    "e2e": "npm run test:e2e",
    "e2e:fullstack": "npm run test:e2e:fullstack",
    "e2e:fullstack:smoke": "npm run test:e2e:fullstack:smoke"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "@vitest/coverage-v8": "^4.1.8",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  },
  "overrides": {
    "js-cookie": "^3.0.8",
    "undici": "7.28.0"
  }
}
