{
  "name": "language-coach-frontend",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:ci": "vitest run --pool=forks --no-file-parallelism --testTimeout=5000 --teardownTimeout=5000",
    "test:e2e": "playwright test",
    "test:e2e:fullstack": "playwright test -c playwright.fullstack.config.ts",
    "e2e": "npm run test:e2e",
    "e2e:fullstack": "npm run test:e2e:fullstack"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9"
  }
}
