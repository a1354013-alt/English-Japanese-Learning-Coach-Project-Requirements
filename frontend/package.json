{
  "name": "language-coach-frontend",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-with-esbuild-temp.mjs vite",
    "typecheck": "node scripts/run-with-esbuild-temp.mjs vue-tsc --noEmit",
    "build": "node scripts/run-with-esbuild-temp.mjs vue-tsc && node scripts/run-with-esbuild-temp.mjs vite build",
    "preview": "node scripts/run-with-esbuild-temp.mjs vite preview",
    "test": "node scripts/run-with-esbuild-temp.mjs vitest run",
    "test:ci": "node scripts/run-with-esbuild-temp.mjs vitest run --pool=forks --no-file-parallelism --testTimeout=5000 --teardownTimeout=5000",
    "e2e": "playwright test",
    "e2e:fullstack": "playwright test -c playwright.fullstack.config.ts"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^25.6.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^27.4.0",
    "typescript": "^5.7.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  }
}
