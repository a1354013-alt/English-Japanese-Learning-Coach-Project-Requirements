# Language Coach Configuration
# Copy this file to .env and adjust values for your environment

# ============ Ollama LLM Settings ============
# Base URL for Ollama API (local or remote)
OLLAMA_URL=http://localhost:11434

# Primary model for lesson generation and analysis
# Recommended: llama3.1:8b, qwen2.5:7b, or mistral:7b
MODEL_NAME=llama2:13b

# Smaller model for quick tasks (optional)
SMALL_MODEL_NAME=llama3:8b

# Larger model for complex reasoning (optional)
LARGE_MODEL_NAME=llama2:13b

# ============ Data Storage ============
# Base directory for all application data
DATA_DIR=../data

# SQLite database file path
DB_PATH=../data/language_coach.db

# ChromaDB vector store for RAG (vocabulary semantic search)
CHROMA_DB_PATH=../data/chroma_db

# ============ Cache Settings ============
# Redis connection URL for distributed caching
# Leave empty to use in-memory cache (development only)
REDIS_URL=redis://localhost:6379/0

# Cache expiration time in seconds (default: 1 hour)
CACHE_EXPIRE=3600

# ============ Scheduler Settings ============
# Daily automatic lesson generation time (HH:MM format, local timezone)
AUTO_GENERATE_TIME=07:30

# Timezone for scheduling and date calculations
# Use IANA timezone format (e.g., Asia/Taipei, America/New_York, Europe/London)
TIMEZONE=Asia/Taipei

# ============ API Server Settings ============
# Host address to bind the FastAPI server
API_HOST=0.0.0.0

# Port number for the API server
API_PORT=8000

# ============ CORS Settings ============
# Comma-separated list of allowed browser origins for CORS
# Do NOT use JSON array format - use comma-separated strings
# Add your frontend development server URL here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============ Authentication (Demo Mode) ============
# Temporary single-user ID until real authentication is implemented
# Change this to identify different users in demo mode
DEFAULT_USER_ID=default_user

# ============ Optional Advanced Settings ============
# TTS Service (future feature)
# TTS_PROVIDER=azure  # Options: azure, google, edge-tts
# TTS_API_KEY=your_api_key_here

# Export Settings
# PDF_EXPORT_ENABLED=true
# EXPORT_DIR=../data/exports
